# Copy this file to .env and fill in real values. .env is gitignored.
# TripCluster auto-loads .env from the project directory on startup.

# Optional — enable traffic-aware routing via TomTom (off by default; uses OSRM).
# Requires TOMTOM_API_KEY when enabled.
# TRIPCLUSTER_USE_TRAFFIC=true
# TOMTOM_API_KEY=your_key_here

# Recommended — Nominatim requires a descriptive User-Agent with a real contact email.
# Do NOT use placeholder addresses like your-email@example.com (Nominatim returns HTTP 403).
# Leave this line commented out to use the built-in default (fine for personal use):
# NOMINATIM_USER_AGENT=TripCluster/0.1.0 (you@gmail.com)
